<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Task Manager{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="css/style.css">
    {% block extra_styles %}{% endblock %}
</head>
<body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <div class="spinner-overlay" id="loadingSpinner" role="alert" aria-live="assertive" aria-label="Loading">
        <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"><span class="visually-hidden">Loading...</span></div>
    </div>
    <header class="header" role="banner">
        <h1>{% block header_title %}Task Manager{% endblock %}</h1>
        {% block header_extra %}{% endblock %}
    </header>
    <div class="toast-container" aria-live="polite" aria-atomic="true" id="toastContainer"></div>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    <div class="container-fluid main-container">
        <div class="row h-100">
            {% block sidebar %}{% endblock %}
            <main class="right-panel" id="main-content" role="main">
                <div class="right-panel-content">
                    {% block content %}{% endblock %}
                </div>
            </main>
        </div>
    </div>
    {% block modals %}{% endblock %}
    {% block shortcuts %}{% endblock %}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    {% block scripts %}{% endblock %}
</body>
</html>
