Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /public/

    # If the requested filename is not a real file or directory, send to index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [QSA,L]
</IfModule>
